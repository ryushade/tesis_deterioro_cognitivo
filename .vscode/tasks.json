{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Frontend",
			"type": "shell",
			"command": "npm",
			"args": ["run", "dev"],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start Backend",
			"type": "shell",
			"command": "C:/Users/Marco/Desktop/tesis_deterioro_cognitivo/.venv/Scripts/python.exe",
			"args": ["run.py"],
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Initialize Database",
			"type": "shell",
			"command": "C:/Users/Marco/Desktop/tesis_deterioro_cognitivo/.venv/Scripts/python.exe",
			"args": ["init_db.py"],
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": "build"
		},
		{
			"label": "Start Docker Services",
			"type": "shell",
			"command": "docker-compose",
			"args": ["up", "-d"],
			"group": "build"
		}
	]
}